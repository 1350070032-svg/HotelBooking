<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — LUMIÈRE HOTEL</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --gold: #C9A84C;
            --gold-light: #E8C97A;
            --gold-dim: #8A6F35;
            --black: #0A0A0A;
            --dark: #111111;
            --dark2: #1A1A1A;
            --dark3: #242424;
            --white: #F5F0E8;
            --white-dim: rgba(245,240,232,0.6);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'Montserrat', sans-serif;
            background: var(--black);
            color: var(--white);
            min-height: 100vh;
        }

        /* ===== NAVBAR ===== */
        .navbar {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
            padding: 0 60px;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: linear-gradient(to bottom, rgba(0,0,0,0.95), transparent);
            border-bottom: 1px solid rgba(201,168,76,0.15);
            backdrop-filter: blur(10px);
            transition: background 0.3s;
        }

        .navbar.scrolled {
            background: rgba(10,10,10,0.98);
            border-bottom-color: rgba(201,168,76,0.3);
        }

        .navbar-brand {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.8rem;
            font-weight: 300;
            letter-spacing: 0.3em;
            color: var(--gold) !important;
            text-decoration: none;
            text-transform: uppercase;
        }

        .navbar-brand span {
            color: var(--white);
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 40px;
            list-style: none;
        }

        .nav-links a {
            font-size: 0.7rem;
            font-weight: 500;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--white-dim);
            text-decoration: none;
            transition: color 0.3s;
            position: relative;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -4px; left: 0;
            width: 0; height: 1px;
            background: var(--gold);
            transition: width 0.3s;
        }

        .nav-links a:hover { color: var(--gold); }
        .nav-links a:hover::after { width: 100%; }

        .nav-btn {
            font-size: 0.65rem !important;
            font-weight: 600 !important;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--black) !important;
            background: var(--gold);
            padding: 10px 24px !important;
            border: none;
            transition: background 0.3s, transform 0.2s !important;
        }

        .nav-btn::after { display: none !important; }
        .nav-btn:hover {
            background: var(--gold-light) !important;
            transform: translateY(-1px);
            color: var(--black) !important;
        }

        /* ===== HERO ===== */
        .hero {
            height: 100vh;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .hero-bg {
            position: absolute;
            inset: 0;
            background-image: url('https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=1920&q=80');
            background-size: cover;
            background-position: center;
            filter: brightness(0.35);
            transform: scale(1.05);
            animation: heroZoom 20s ease-in-out infinite alternate;
        }

        @@keyframes heroZoom {
            from { transform: scale(1.05); }
            to   { transform: scale(1.12); }
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(
                to bottom,
                rgba(0,0,0,0.2) 0%,
                rgba(0,0,0,0.1) 40%,
                rgba(0,0,0,0.6) 100%
            );
        }

        .hero-content {
            position: relative;
            text-align: center;
            padding: 0 20px;
            animation: fadeUp 1.2s ease both;
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(40px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .hero-eyebrow {
            font-size: 0.65rem;
            letter-spacing: 0.5em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
        }

        .hero-eyebrow::before,
        .hero-eyebrow::after {
            content: '';
            width: 40px; height: 1px;
            background: var(--gold);
        }

        .hero-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(3rem, 8vw, 7rem);
            font-weight: 300;
            line-height: 1.05;
            letter-spacing: 0.05em;
            color: var(--white);
            margin-bottom: 24px;
        }

        .hero-title em {
            color: var(--gold);
            font-style: italic;
        }

        .hero-subtitle {
            font-size: 0.75rem;
            letter-spacing: 0.25em;
            color: var(--white-dim);
            margin-bottom: 50px;
            text-transform: uppercase;
        }

        .hero-btns {
            display: flex;
            gap: 16px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-gold {
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--black);
            background: var(--gold);
            padding: 16px 40px;
            text-decoration: none;
            border: 1px solid var(--gold);
            transition: all 0.3s;
            display: inline-block;
        }

        .btn-gold:hover {
            background: transparent;
            color: var(--gold);
        }

        .btn-outline {
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--white);
            background: transparent;
            padding: 16px 40px;
            text-decoration: none;
            border: 1px solid rgba(255,255,255,0.4);
            transition: all 0.3s;
            display: inline-block;
        }

        .btn-outline:hover {
            border-color: var(--gold);
            color: var(--gold);
        }

        /* ===== BOOKING BAR ===== */
        .booking-bar {
            background: var(--dark2);
            border-top: 1px solid rgba(201,168,76,0.2);
            border-bottom: 1px solid rgba(201,168,76,0.2);
            padding: 32px 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0;
            flex-wrap: wrap;
        }

        .booking-field {
            flex: 1;
            min-width: 180px;
            padding: 0 32px;
            border-right: 1px solid rgba(201,168,76,0.2);
        }

        .booking-field:last-child { border-right: none; }

        .booking-label {
            font-size: 0.55rem;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .booking-input {
            background: transparent;
            border: none;
            color: var(--white);
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.1rem;
            font-weight: 300;
            width: 100%;
            outline: none;
            cursor: pointer;
        }

        .booking-input::placeholder { color: var(--white-dim); }

        .booking-btn {
            background: var(--gold);
            color: var(--black);
            border: none;
            padding: 20px 48px;
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.3s;
            white-space: nowrap;
            margin-left: 32px;
        }

        .booking-btn:hover { background: var(--gold-light); }

        /* ===== SECTION TITLES ===== */
        .section {
            padding: 100px 60px;
        }

        .section-header {
            text-align: center;
            margin-bottom: 70px;
        }

        .section-tag {
            font-size: 0.6rem;
            letter-spacing: 0.5em;
            text-transform: uppercase;
            color: var(--gold);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            margin-bottom: 20px;
        }

        .section-tag::before,
        .section-tag::after {
            content: '';
            width: 30px; height: 1px;
            background: var(--gold);
        }

        .section-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2rem, 4vw, 3.5rem);
            font-weight: 300;
            line-height: 1.1;
            color: var(--white);
        }

        .section-title em { color: var(--gold); font-style: italic; }

        /* ===== ROOM CARDS ===== */
        .rooms-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: 2px;
            background: rgba(201,168,76,0.1);
        }

        .room-card {
            background: var(--dark2);
            overflow: hidden;
            position: relative;
            group: true;
            text-decoration: none;
            display: block;
            transition: transform 0.4s;
        }

        .room-card:hover { z-index: 2; }

        .room-img {
            width: 100%;
            height: 280px;
            object-fit: cover;
            display: block;
            filter: brightness(0.75);
            transition: filter 0.5s, transform 0.6s;
        }

        .room-card:hover .room-img {
            filter: brightness(0.9);
            transform: scale(1.04);
        }

        .room-img-wrap {
            overflow: hidden;
            position: relative;
        }

        .room-badge {
            position: absolute;
            top: 20px; left: 20px;
            background: var(--gold);
            color: var(--black);
            font-size: 0.55rem;
            font-weight: 600;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            padding: 6px 14px;
        }

        .room-body {
            padding: 32px;
            border-top: 1px solid rgba(201,168,76,0.15);
        }

        .room-name {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.6rem;
            font-weight: 400;
            color: var(--white);
            margin-bottom: 10px;
        }

        .room-desc {
            font-size: 0.75rem;
            color: var(--white-dim);
            line-height: 1.7;
            margin-bottom: 24px;
            letter-spacing: 0.05em;
        }

        .room-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .room-price {
            font-family: 'Cormorant Garamond', serif;
        }

        .room-price-amount {
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--gold);
            line-height: 1;
        }

        .room-price-unit {
            font-size: 0.6rem;
            letter-spacing: 0.2em;
            color: var(--white-dim);
            text-transform: uppercase;
        }

        .room-cta {
            font-size: 0.6rem;
            font-weight: 600;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--gold);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: gap 0.3s;
        }

        .room-card:hover .room-cta { gap: 14px; }

        /* ===== AMENITIES ===== */
        .amenities-section {
            background: var(--dark2);
            border-top: 1px solid rgba(201,168,76,0.1);
            border-bottom: 1px solid rgba(201,168,76,0.1);
        }

        .amenities-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1px;
            background: rgba(201,168,76,0.1);
        }

        .amenity-item {
            background: var(--dark2);
            padding: 48px 32px;
            text-align: center;
            transition: background 0.3s;
        }

        .amenity-item:hover { background: var(--dark3); }

        .amenity-icon {
            font-size: 2rem;
            color: var(--gold);
            margin-bottom: 16px;
            display: block;
        }

        .amenity-name {
            font-size: 0.65rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--white-dim);
        }

        /* ===== REVIEWS ===== */
        .review-card {
            background: var(--dark2);
            border: 1px solid rgba(201,168,76,0.15);
            padding: 40px;
            position: relative;
        }

        .review-quote {
            font-family: 'Cormorant Garamond', serif;
            font-size: 4rem;
            color: var(--gold);
            line-height: 0.5;
            margin-bottom: 24px;
            opacity: 0.5;
        }

        .review-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.15rem;
            font-style: italic;
            color: var(--white-dim);
            line-height: 1.7;
            margin-bottom: 28px;
        }

        .review-stars { color: var(--gold); font-size: 0.8rem; margin-bottom: 12px; }

        .review-author {
            font-size: 0.65rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--gold);
        }

        .reviews-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 24px;
        }

        /* ===== FOOTER ===== */
        footer {
            background: var(--black);
            border-top: 1px solid rgba(201,168,76,0.2);
            padding: 60px;
            text-align: center;
        }

        .footer-logo {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 300;
            letter-spacing: 0.4em;
            color: var(--gold);
            text-transform: uppercase;
            margin-bottom: 24px;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            gap: 40px;
            list-style: none;
            margin-bottom: 40px;
        }

        .footer-links a {
            font-size: 0.6rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--white-dim);
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer-links a:hover { color: var(--gold); }

        .footer-copy {
            font-size: 0.6rem;
            letter-spacing: 0.15em;
            color: rgba(245,240,232,0.3);
        }

        .divider {
            width: 60px; height: 1px;
            background: var(--gold);
            margin: 0 auto 20px;
        }

        /* ===== ALERT ===== */
        .alert-gold {
            background: rgba(201,168,76,0.1);
            border: 1px solid var(--gold-dim);
            color: var(--gold-light);
            padding: 16px 24px;
            font-size: 0.8rem;
            letter-spacing: 0.05em;
            margin-bottom: 24px;
        }

        /* ===== MAIN CONTENT PAD ===== */
        .main-content {
            padding-top: 80px;
        }

        /* ===== SCROLL INDICATOR ===== */
        .scroll-indicator {
            position: absolute;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            animation: bounce 2s infinite;
        }

        .scroll-indicator span {
            font-size: 0.55rem;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            color: var(--white-dim);
        }

        .scroll-line {
            width: 1px;
            height: 40px;
            background: linear-gradient(to bottom, var(--gold), transparent);
        }

        @@keyframes bounce {
            0%, 100% { transform: translateX(-50%) translateY(0); }
            50% { transform: translateX(-50%) translateY(8px); }
        }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 768px) {
            .navbar { padding: 0 24px; }
            .nav-links { gap: 20px; }
            .section { padding: 60px 24px; }
            .booking-bar { padding: 24px; flex-direction: column; }
            .booking-field { border-right: none; border-bottom: 1px solid rgba(201,168,76,0.2); padding: 16px 0; width: 100%; }
            .booking-btn { margin-left: 0; margin-top: 16px; width: 100%; }
            footer { padding: 40px 24px; }
        }
    </style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar" id="mainNav">
    <a class="navbar-brand" href="/">LU<span>MIÈRE</span></a>
    <ul class="nav-links">
        <li><a href="/">Trang chủ</a></li>
        <li><a href="/Room">Phòng</a></li>
        <li><a href="/Booking/MyBookings">Đặt phòng</a></li>
        @if (User.Identity?.IsAuthenticated == true)
        {
            if (User.IsInRole("Admin"))
            {
                <li><a href="/Admin/Dashboard">Admin</a></li>
            }
            <li>
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                    <button type="submit" style="background:none;border:none;cursor:pointer;font-family:inherit" class="nav-links">
                        <a style="color:var(--white-dim)">Đăng xuất</a>
                    </button>
                </form>
            </li>
        }
        else
        {
            <li><a href="/Account/Login">Đăng nhập</a></li>
            <li><a href="/Account/Register" class="nav-btn">Đăng ký</a></li>
        }
    </ul>
</nav>

<div class="main-content">
    @RenderBody()
</div>

<!-- FOOTER -->
<footer>
    <div class="footer-logo">Lumière</div>
    <div class="divider"></div>
    <ul class="footer-links">
        <li><a href="/">Trang chủ</a></li>
        <li><a href="/Room">Phòng</a></li>
        <li><a href="/Account/Login">Đăng nhập</a></li>
        <li><a href="#">Liên hệ</a></li>
    </ul>
    <p class="footer-copy">© 2026 Lumière Hotel. All rights reserved.</p>
</footer>

<script>
    // Navbar scroll effect
    window.addEventListener('scroll', () => {
        document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 50);
    });
</script>

@RenderSection("Scripts", required: false)
</body>
</html>
