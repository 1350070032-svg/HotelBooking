@model HotelBooking.Models.Room
@{
    ViewData["Title"] = Model.Name;
}

<div style="padding-top:80px;">

    <!-- ẢNH HERO PHÒNG -->
    <div style="position:relative;height:70vh;overflow:hidden;">
        <img src="@Model.ImageUrl"
             onerror="this.src='https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=1920&q=80'"
             style="width:100%;height:100%;object-fit:cover;filter:brightness(0.45);" />
        <div style="position:absolute;inset:0;background:linear-gradient(to bottom,transparent 40%,rgba(0,0,0,0.9));"></div>
        <div style="position:absolute;bottom:60px;left:60px;">
            <div style="font-size:0.6rem;letter-spacing:0.5em;text-transform:uppercase;color:var(--gold);margin-bottom:12px;">
                — Chi tiết phòng —
            </div>
            <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,5vw,4.5rem);font-weight:300;color:var(--white);margin-bottom:8px;">
                @Model.Name
            </h1>
            <p style="font-size:0.75rem;letter-spacing:0.15em;color:var(--white-dim);">@Model.Description</p>
        </div>
    </div>

    <!-- NỘI DUNG CHÍNH -->
    <div style="display:grid;grid-template-columns:1fr 400px;gap:0;max-width:1400px;margin:0 auto;padding:60px;">

        <!-- CỘT TRÁI - Thông tin -->
        <div style="padding-right:60px;border-right:1px solid rgba(201,168,76,0.15);">

            <!-- Thông tin nhanh -->
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(201,168,76,0.1);margin-bottom:50px;">
                <div style="background:var(--dark2);padding:32px;text-align:center;">
                    <div style="font-size:1.5rem;color:var(--gold);margin-bottom:8px;">👥</div>
                    <div style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:var(--white);">@Model.Capacity</div>
                    <div style="font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--white-dim);">Người</div>
                </div>
                <div style="background:var(--dark2);padding:32px;text-align:center;">
                    <div style="font-size:1.5rem;color:var(--gold);margin-bottom:8px;">🛏️</div>
                    <div style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:var(--white);">@Model.AvailableRooms</div>
                    <div style="font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--white-dim);">Phòng trống</div>
                </div>
                <div style="background:var(--dark2);padding:32px;text-align:center;">
                    <div style="font-size:1.5rem;color:var(--gold);margin-bottom:8px;">✨</div>
                    <div style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:@(Model.IsAvailable ? "var(--gold)" : "#e07070");">
                        @(Model.IsAvailable ? "Còn" : "Hết")
                    </div>
                    <div style="font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--white-dim);">Tình trạng</div>
                </div>
            </div>

            <!-- Tiện nghi -->
            <div style="margin-bottom:40px;">
                <div style="font-size:0.6rem;letter-spacing:0.4em;text-transform:uppercase;color:var(--gold);margin-bottom:24px;display:flex;align-items:center;gap:12px;">
                    <span style="width:30px;height:1px;background:var(--gold);display:inline-block;"></span>
                    Tiện nghi phòng
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    @foreach (var item in new[] {
                        ("🌡️","Điều hòa nhiệt độ"),("📺","TV màn hình phẳng"),
                        ("🛁","Bồn tắm/vòi hoa sen"),("☕","Máy pha cà phê"),
                        ("🔒","Két an toàn"),("🪟","View đẹp")
                    })
                    {
                        <div style="display:flex;align-items:center;gap:12px;padding:12px;border:1px solid rgba(201,168,76,0.1);">
                            <span style="font-size:1.2rem;">@item.Item1</span>
                            <span style="font-size:0.7rem;letter-spacing:0.05em;color:var(--white-dim);">@item.Item2</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Đánh giá -->
            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                <div>
                    <div style="font-size:0.6rem;letter-spacing:0.4em;text-transform:uppercase;color:var(--gold);margin-bottom:24px;display:flex;align-items:center;gap:12px;">
                        <span style="width:30px;height:1px;background:var(--gold);display:inline-block;"></span>
                        Đánh giá khách hàng
                    </div>
                    @foreach (var r in Model.Reviews)
                    {
                        <div style="border:1px solid rgba(201,168,76,0.15);padding:28px;margin-bottom:16px;">
                            <div style="color:var(--gold);margin-bottom:8px;">@string.Concat(Enumerable.Repeat("★", r.Rating))@string.Concat(Enumerable.Repeat("☆", 5 - r.Rating))</div>
                            <p style="font-family:'Cormorant Garamond',serif;font-style:italic;color:var(--white-dim);font-size:1.05rem;line-height:1.7;margin-bottom:12px;">@r.Comment</p>
                            <div style="font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);">@(r.User?.FullName ?? "Khách ẩn danh")</div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- CỘT PHẢI - Form đặt phòng -->
        <div style="padding-left:60px;">
            <div style="position:sticky;top:100px;">

                <!-- Giá -->
                <div style="text-align:center;padding:40px;border:1px solid rgba(201,168,76,0.3);margin-bottom:24px;">
                    <div style="font-size:0.6rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--white-dim);margin-bottom:8px;">Giá từ</div>
                    <div style="font-family:'Cormorant Garamond',serif;font-size:3rem;color:var(--gold);line-height:1;">@Model.PricePerNight.ToString("N0")</div>
                    <div style="font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--white-dim);">VNĐ / đêm</div>
                </div>

                @if (TempData["Error"] != null)
                {
                    <div style="background:rgba(180,50,50,0.2);border:1px solid #e07070;color:#e07070;padding:16px;margin-bottom:16px;font-size:0.8rem;">
                        ⚠️ @TempData["Error"]
                    </div>
                }
                @if (TempData["Success"] != null)
                {
                    <div style="background:rgba(50,180,50,0.2);border:1px solid #70e070;color:#70e070;padding:16px;margin-bottom:16px;font-size:0.8rem;">
                        ✓ @TempData["Success"]
                    </div>
                }

                @if (Model.IsAvailable && Model.AvailableRooms > 0)
                {
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Booking" asp-action="Create" method="post">
                            <input type="hidden" name="roomId" value="@Model.Id" />
                            <div style="margin-bottom:16px;">
                                <label style="font-size:0.6rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:8px;">Ngày nhận phòng</label>
                                <input type="date" name="checkIn" required
                                       style="width:100%;background:var(--dark2);border:1px solid rgba(201,168,76,0.3);color:var(--white);padding:14px 16px;font-family:inherit;font-size:0.9rem;" />
                            </div>
                            <div style="margin-bottom:24px;">
                                <label style="font-size:0.6rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:8px;">Ngày trả phòng</label>
                                <input type="date" name="checkOut" required
                                       style="width:100%;background:var(--dark2);border:1px solid rgba(201,168,76,0.3);color:var(--white);padding:14px 16px;font-family:inherit;font-size:0.9rem;" />
                            </div>
                            <button type="submit" class="btn-gold" style="width:100%;padding:18px;font-size:0.7rem;text-align:center;border:none;cursor:pointer;">
                                ĐẶT PHÒNG NGAY
                            </button>
                        </form>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn-gold" style="display:block;text-align:center;padding:18px;font-size:0.7rem;">
                            ĐĂNG NHẬP ĐỂ ĐẶT PHÒNG
                        </a>
                    }
                }
                else
                {
                    <div style="text-align:center;padding:18px;border:1px solid #6b2d2d;color:#e07070;font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;">
                        HẾT PHÒNG
                    </div>
                }

                <a href="/Room" style="display:block;text-align:center;margin-top:16px;font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--white-dim);text-decoration:none;">
                    ← Xem phòng khác
                </a>
            </div>
        </div>
    </div>
</div>